{
  "name": "ec-module",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2024-09-23",
    "deploy": "wrangler pages deploy public",
    "db:migrations:apply:local": "wrangler d1 migrations apply ec_db --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply ec_db --remote",
    "data:clear:local": "wrangler d1 execute ec_db --local --file scripts/clear-sample-data.sql",
    "data:clear:remote": "wrangler d1 execute ec_db --remote --file scripts/clear-sample-data.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.90.0"
  }
}
